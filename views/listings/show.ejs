<% layout("/layouts/boilerplate") %>

  <div class="container mt-4" style="max-width: 900px;">

    <!-- IMAGE -->
    <img src="<%= listing.image.url %>" class="img-fluid rounded-4 mb-4"
      style="height: 420px; width: 100%; object-fit: cover;">

    <!-- TITLE -->
    <h2 class="fw-bold mb-1">
      <%= listing.title %>
    </h2>

    <!-- LOCATION -->
    <p class="text-muted mb-2">
      <i class="fa-solid fa-location-dot"></i>
      <%= listing.location %>, <%= listing.country %>
    </p>

    <!-- PRICE -->
    <h5 class="mb-3">
      ₹ <%= listing.price.toLocaleString("en-IN") %>
        <span class="text-muted">/ night</span>
    </h5>

    <!-- OWNER -->
    <p class="text-muted mb-4">
      Hosted by <b>
        <%= listing.owner.username %>
      </b>
    </p>

    <hr>

    <!-- DESCRIPTION -->
    <h5>Description</h5>
    <p class="text-secondary">
      <%= listing.description %>
    </p>

    <!-- ACTION BUTTONS -->
    <% if(currUser && currUser._id.toString()===listing.owner._id.toString()) { %>
      <div class="d-flex gap-2 mt-3 mb-4">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark rounded-pill px-4">Edit</a>

        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
          <button class="btn btn-outline-dark rounded-pill px-4">Delete</button>
        </form>
      </div>
      <% } %>

        <hr>

        <!-- REVIEWS -->
        <% if(listing.reviews.length> 0) { %>
          <h5 class="mb-3">Reviews</h5>

          <% listing.reviews.forEach(review=> { %>
            <div class="mb-3 p-3 border rounded-4">

              <h6 class="mb-1">@<%= review.author.username %>
              </h6>

              <!-- Dynamic Stars -->
              <div class="text-warning mb-1">
                <% for(let i=0;i<review.rating;i++){ %> ⭐ <% } %>
              </div>

              <p class="mb-2">
                <%= review.comment %>
              </p>

              <% if(currUser && review.author._id.toString()===currUser._id.toString()) { %>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-dark rounded-pill">Delete</button>
                </form>
                <% } %>

            </div>
            <% }) %>
              <% } %>

                <!-- MAP -->
                <h5 class="mt-4 mb-2">Where you'll be</h5>

                <div class="rounded-4 overflow-hidden mb-4">
                  <div id="map" style="height: 350px;"></div>
                </div>

  </div>

  <!-- LEAFLET -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

  <!-- MAP SCRIPT -->
  <script>
    document.addEventListener("DOMContentLoaded", function () {

      const lat = Number("<%= listing.geolocation?.lat || 20.5937 %>");
      const lon = Number("<%= listing.geolocation?.lon || 78.9629 %>");

      const map = L.map('map').setView([lat, lon], 6);

      L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

      L.marker([lat, lon]).addTo(map)
        .bindPopup("<%- listing.title %>")
        .openPopup();

    });
  </script>